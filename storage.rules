rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Proof of payment uploads: authenticated users can upload to their order paths
    match /proof_of_payment/{orderId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10MB max
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Comment image uploads: authenticated users can attach images to order comments
    match /comment_images/{orderId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Product image uploads: authenticated users can upload product images
    match /product_images/{productName}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
